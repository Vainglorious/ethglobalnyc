# Polymarket integration — environment template.
#
# Copy to `.env` and fill in the secret values. `.env` is gitignored.
# Polymarket runs on POLYGON MAINNET only (there is no testnet), so any order
# placed here spends REAL USDC.e. Use a dedicated wallet with a tiny balance.
#
#   cp polymarket/.env.example polymarket/.env
#   # edit polymarket/.env
#
# ---------------------------------------------------------------------------
# Network (safe defaults; rarely need changing)
# ---------------------------------------------------------------------------
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com
POLYGON_CHAIN_ID=137
POLYGON_RPC_URL=https://polygon-rpc.com

# ---------------------------------------------------------------------------
# Wallet / auth  (SECRET — leave blank in the committed example)
# ---------------------------------------------------------------------------
# Private key of the trading wallet (0x-prefixed). This wallet must hold USDC.e
# (for stake) and a little MATIC/POL (for the one-time allowance approvals).
POLYMARKET_PRIVATE_KEY=

# Signature type:
#   0 = plain EOA (recommended for an API bot; funds live in the EOA itself)
#   1 = Polymarket email/magic proxy account  -> set FUNDER to the proxy address
#   2 = Polymarket browser-wallet (Safe) proxy -> set FUNDER to the proxy address
POLYMARKET_SIGNATURE_TYPE=0
# Only needed when SIGNATURE_TYPE is 1 or 2 (the proxy wallet that holds funds):
POLYMARKET_FUNDER_ADDRESS=

# CLOB API credentials (L2). Leave blank to auto-derive from the private key on
# first run; check_account.py will print them so you can paste them back here to
# skip re-deriving every time.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
