# PolyGun Telegram userbot config.
#
# Get TG_API_ID + TG_API_HASH from https://my.telegram.org -> "API development tools"
# (log in with your phone, create an app; any name/short-name works).
#
#   cp polygun/.env.example polygun/.env   # then fill in the values

TG_API_ID=
TG_API_HASH=
TG_PHONE=          # your Telegram phone, e.g. +14155551234

# The PolyGun bot username (no @).
PG_BOT=PolyGunSniperBot
