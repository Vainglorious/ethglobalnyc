# World Agent Kit (Worldcoin rail) — env template.   cp .env.example .env
#
# AgentKit is an x402 extension that proves an agent is human-backed.
# The docs (worldcoin/docs/agent-kit-integrate.md) do NOT publish fixed env-var
# names, so the names below are OUR convention. Marked [confirmed from docs] vs
# [TBD / to verify]. The real .env is gitignored — never commit secrets.

# --- Agent wallet (the address a verified human registers) ---
# [TBD] private key the agent signs with. Keep secret. May move to a keystore later.
WORLD_AGENT_PRIVATE_KEY=
# [TBD] the agent wallet address (derived from the key above).
WORLD_AGENT_ADDRESS=

# --- Chain ---
# [confirmed] eip155:480 = World Chain, eip155:8453 = Base.
# OPEN QUESTION: must this agree with Arc, where Colony settles money? (see docs §open)
WORLD_AGENT_CHAIN_ID=eip155:480

# --- x402 facilitator ---
# [confirmed] default facilitator from the docs.
WORLD_AGENT_FACILITATOR_URL=https://x402-worldchain.vercel.app/facilitator

# --- Payments ---
# [confirmed] USDC on World Chain.
WORLD_USDC_ADDRESS=0x79A02482A880bCE3F13e09Da970dC34db4CD24d1
# [TBD] the address that receives payment on the server side (payTo).
WORLD_PAY_TO=

# Note: AgentKit verification runs through the World App flow (human proof),
# not an API key — so there is no WORLD_API_KEY here unless the live docs add one.
