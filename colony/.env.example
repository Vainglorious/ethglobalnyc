# Colony ENS identity settings.
#
# These values let the generation and publisher commands reuse the same ENS parent
# without repeating flags in every command.

COLONY_ENS_PARENT=colonny.eth
COLONY_ENS_VERSION=v2
COLONY_PROFILE_BASE_URL=https://colony.app/ants
COLONY_WORLD_VERIFICATIONS=colony/secrets/world-agentkit-verifications.local.json

# Agent wallet provider.
#
# local   = throwaway EVM keypairs; private keys are stored in the gitignored wallet store.
# dynamic = Dynamic V3 WaaS/MPC wallets; no raw private key is returned, only wallet metadata.
# Dynamic credentials may live here or in dynamic/.env.

COLONY_WALLET_PROVIDER=local
COLONY_DYNAMIC_ENV=dynamic/.env
COLONY_DYNAMIC_WALLET_IDENTIFIER_PREFIX=colony-ant
COLONY_DYNAMIC_WALLET_IDENTIFIER_DOMAIN=colony.test
COLONY_DYNAMIC_WALLET_TIMEOUT_SECONDS=30

# Sepolia ENS publishing.
#
# PROJECT_ENS_PRIVATE_KEY is the publisher key. The script derives and prints the
# publisher address, so do not duplicate it in another env var.

SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
PROJECT_ENS_PRIVATE_KEY=

# Colony optional LLM voice settings.
#
# The harness runs without these values in deterministic template mode.
# To use OpenRouter for debate speaker messages:
#
#   cp colony/.env.example colony/.env
#   edit colony/.env
#   python3 colony/run_demo.py --voice-mode llm
#
# Confirmed from OpenRouter docs:
# - base URL: https://openrouter.ai/api/v1
# - chat path: /chat/completions
# - auth header: Authorization: Bearer <OPENROUTER_API_KEY>
# - optional attribution headers: HTTP-Referer and X-OpenRouter-Title

COLONY_LLM_PROVIDER=openrouter

# You can also set OPENROUTER_API_KEY instead.
COLONY_LLM_API_KEY=
COLONY_LLM_BASE_URL=https://openrouter.ai/api/v1
COLONY_LLM_MODEL=deepseek/deepseek-v4-flash
COLONY_LLM_TIMEOUT_SECONDS=30

OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Colony Harness

# Optional X/social availability scout.
# Keep disabled unless you explicitly run `run_match.py --include-x`.
# `SCRAPECREATORS_X_SEARCH_URL` can be either:
# - a GET URL template containing `{query}`; or
# - a POST endpoint that accepts JSON: {"query": "..."}.
#
# Example:
# SCRAPECREATORS_API_KEY=
# SCRAPECREATORS_X_SEARCH_URL=https://example.com/twitter/search?query={query}

SCRAPECREATORS_API_KEY=
SCRAPECREATORS_X_SEARCH_URL=

# Optional Telegram social/news scout.
# Keep disabled unless you explicitly run `run_match.py --include-telegram`.
# Easiest path: export messages to JSON and point COLONY_TELEGRAM_SCOUT_JSON at it.
# Live mode reuses a Telethon session and requires COLONY_TELEGRAM_CHATS.

COLONY_TELEGRAM_SCOUT_JSON=
COLONY_TELEGRAM_ENABLE_LIVE=0
COLONY_TELEGRAM_CHATS=
COLONY_TELEGRAM_ENV=polygun/.env
COLONY_TELEGRAM_SESSION=polygun/pg

# Optional PolyGun read-only snapshot scout.
# Generate with:
#   polygun/.venv/bin/python polygun/pg.py snapshot --out polygun/snapshots/latest.json

COLONY_POLYGUN_SNAPSHOT_JSON=polygun/snapshots/latest.json

# Optional native CAMEL integration marker. The current harness has a fallback
# research scout; set this to 1 only after installing/configuring camel-ai.
COLONY_CAMEL_USE_NATIVE=0
COLONY_CAMEL_MODEL_PLATFORM=OPENROUTER
COLONY_CAMEL_MODEL=deepseek/deepseek-v4-flash
COLONY_CAMEL_BASE_URL=https://openrouter.ai/api/v1
COLONY_CAMEL_API_KEY=
