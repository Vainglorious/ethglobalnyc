# Unlink exploration — env template.   cp .env.example .env
# The real .env is gitignored — never commit the API key or mnemonics.

# From https://dashboard.unlink.xyz  (org -> project -> API Keys). Backend-only.
UNLINK_API_KEY=

# Target testnet. base-sepolia (84532) is simplest; arc-testnet (5042002) is Colony's chain.
UNLINK_ENVIRONMENT=base-sepolia
UNLINK_CHAIN_ID=84532

# App id from the dashboard (used in account derivation).
UNLINK_APP_ID=

# Test ERC-20 token address configured for your environment (from the dashboard project).
UNLINK_TEST_TOKEN=

# Two THROWAWAY BIP-39 mnemonics for the test wallets. Generate with: cast wallet new-mnemonic
UNLINK_WALLET_A_MNEMONIC=
UNLINK_WALLET_B_MNEMONIC=

# Amount to send, in smallest unit (wei-style decimal string). 0.25 token @ 18 decimals:
UNLINK_TRANSFER_AMOUNT=250000000000000000
