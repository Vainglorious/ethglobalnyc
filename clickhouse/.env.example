# ClickHouse rail connection template.
#
#   cp clickhouse/.env.example clickhouse/.env
#   edit clickhouse/.env with your credentials
#
# The real .env is gitignored — never commit the password.

CLICKHOUSE_HOST="h....clickhouse.cloud"
CLICKHOUSE_USER="_hackathon_claude"
CLICKHOUSE_PASSWORD=""

# ClickHouse Cloud uses native TLS on 9440 and HTTPS on 8443.
CLICKHOUSE_PORT=8443
CLICKHOUSE_SECURE=true
