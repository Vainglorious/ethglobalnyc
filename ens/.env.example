# ENS identity plane — example environment.
#
# Tanguy: copy this to `.env` and fill in. `.env` must stay out of git.
#   cp ens/.env.example ens/.env
#
# These are placeholder names — rename/extend to match whatever resolver +
# subname approach you land on (durin-style offchain CCIP-Read is the plan).

# --- Parent name / namespace ---
ENS_PARENT_NAME=colony.eth
ENS_SUBNAME_FORMAT=                 # e.g. {name}-{gen}.colony.eth

# --- Networks / RPC ---
ETH_NETWORK=sepolia                 # or mainnet for the live resolve demo
ETH_RPC_URL=
CHAIN_ID=

# --- Offchain resolver (CCIP-Read gateway) ---
RESOLVER_GATEWAY_URL=               # the gateway your resolver points at
RESOLVER_PRIVATE_KEY=               # signer for offchain answers (KEEP SECRET)
RESOLVER_CONTRACT_ADDRESS=

# --- Account used to set/manage the parent name ---
ENS_OWNER_PRIVATE_KEY=              # KEEP SECRET

# --- Cross-plane binding (see README) ---
# The ant lives on Arc but is named here; store its Arc address in records.
ARC_RPC_URL=

# --- Optional: a public ENS tool to verify resolution against ---
ENS_VERIFY_TOOL_URL=https://app.ens.domains
